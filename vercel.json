{
  "version": 2,
  "framework": null,
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/build",
  "functions": {
    "api/**/*.js": {
      "runtime": "@vercel/node@3.0.0"
    }
  },
  "routes": [
    { "src": "/api/auth/signup", "dest": "/api/auth/signup.js" },
    { "src": "/api/auth/login", "dest": "/api/auth/login.js" },
    { "src": "/api/evaluate", "dest": "/api/evaluate.js" },
    { "src": "/api/chat", "dest": "/api/chat.js" },
    { "src": "/api/history/([^/]+)", "dest": "/api/history/[id].js" },
    { "src": "/api/history", "dest": "/api/history/index.js" },
    { "src": "/(.*)", "dest": "/frontend/build/index.html" }
  ]
}
