{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "build" }
    },
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    { "source": "/api/auth/signup", "destination": "/api/auth/signup.js" },
    { "source": "/api/auth/login", "destination": "/api/auth/login.js" },
    { "source": "/api/evaluate", "destination": "/api/evaluate.js" },
    { "source": "/api/chat", "destination": "/api/chat.js" },
    { "source": "/api/history/:id", "destination": "/api/history/[id].js" },
    { "source": "/api/history", "destination": "/api/history/index.js" },
    { "source": "/(.*)", "destination": "/frontend/build/index.html" }
  ]
}
